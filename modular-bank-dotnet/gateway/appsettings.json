{
  "ReverseProxy": {
    "Routes": {
      "accounts-route": {
        "ClusterId": "accounts-cluster",
        "Match": {
          "Path": "/accounts/{**catch-all}"
        },
        "Priority": 10
      },
      "transfers-route": {
        "ClusterId": "transfers-cluster",
        "Match": {
          "Path": "/transfers/{**catch-all}"
        },
        "Priority": 10
      },
      "catchall-route": {
        "ClusterId": "monolith-cluster",
        "Match": {
          "Path": "/{**catch-all}"
        },
        "Priority": 100
      }
    },
    "Clusters": {
      "accounts-cluster": {
        "Destinations": {
          "accounts-service": {
            "Address": "http://accounts-service:8080"
          }
        },
        "HttpClient": {
          "Timeout": "00:00:30"
        },
        "HttpRequest": {}
      },
      "transfers-cluster": {
        "Destinations": {
          "transfers-service-destination": {
            "Address": "http://transfers-service:8080"
          }
        },
        "HttpClient": {
          "Timeout": "00:00:30"
        },
        "HttpRequest": {}
      },
      "monolith-cluster": {
        "Destinations": {
          "monolith": {
            "Address": "http://monolith:8080"
          }
        },
        "HttpClient": {
          "Timeout": "00:00:30"
        },
        "HttpRequest": {}
      }
    }
  },
  "OpenTelemetry": {
    "ExporterEndpoint": "http://localhost:4317"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Yarp": "Information"
    }
  }
}
